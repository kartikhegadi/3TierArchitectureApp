        <mxCell id="OjZRGnwAGwvgJaNgSmiM-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;b&gt;Deployment of 3-Tier Applications Using AWS Services&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="340" x="120" y="20" as="geometry" />
        </mxCell>
        <mxCell id="OjZRGnwAGwvgJaNgSmiM-2" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;b&gt;Key Components:&lt;/b&gt;&lt;br&gt;● Presentation Tier (Frontend) – Hosted on AWS S3 (Static Website).&lt;br&gt;● Application Tier (Backend) – Runs on AWS EC2 (Web Server).&lt;br&gt;● Database Tier – Managed by AWS RDS (MySQL/PostgreSQL).&lt;br&gt;● Networking &amp;amp; Security – VPC, IAM, Route 53 for access control and DNS." vertex="1">
          <mxGeometry height="80" width="450" x="20" y="70" as="geometry" />
        </mxCell>
        <mxCell id="OjZRGnwAGwvgJaNgSmiM-3" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;b&gt;Business Requirements:&lt;br&gt;&lt;/b&gt;Users should be able to submit data via a web form.&lt;br&gt;Data should be stored securely in a backend database.&lt;br&gt;The application should be accessible via a custom domain (using Route 53).&lt;br&gt;Security best practices should be followed (IAM roles, VPC isolation)" vertex="1">
          <mxGeometry height="100" width="440" x="20" y="160" as="geometry" />
        </mxCell>
